#!/usr/bin/env bash
set -euo pipefail

# kamosu — Host CLI for the kamosu knowledge base toolkit
# Architecture: Host-centric orchestration. Docker used only for LLM (claude) and search (python3).
# Install: curl -fsSL https://raw.githubusercontent.com/hayamiz/kamosu/master/cli/kamosu | sudo install /dev/stdin /usr/local/bin/kamosu

KAMOSU_CLI_VERSION="0.2.0"
KAMOSU_IMAGE="hayamiz/kamosu"
MIN_IMAGE_VERSION="0.2.0"

# Export host UID/GID so containers can create files with matching ownership
export HOST_UID="$(id -u)"
export HOST_GID="$(id -g)"

# ===================================================================
# HELPERS
# ===================================================================

die() {
  echo "kamosu: error: $*" >&2
  exit 1
}

warn() {
  echo "kamosu: warning: $*" >&2
}

info() {
  echo "[kamosu] $1"
}

require_docker() {
  command -v docker >/dev/null 2>&1 || die "Docker is not installed. See https://docs.docker.com/get-docker/"
  docker info >/dev/null 2>&1 || die "Docker daemon is not running. Start Docker and try again."
}

require_data_repo() {
  [[ -f .kamosu-version ]] || die "Not a kamosu data repository (missing .kamosu-version). Run this command from your KB directory."
}

has_help_flag() {
  for arg in "$@"; do
    case "$arg" in
      --help|-h) return 0 ;;
    esac
  done
  return 1
}

image_tag() {
  if [[ -f .kamosu-version ]]; then
    cat .kamosu-version
  else
    echo "latest"
  fi
}

full_image() {
  echo "${KAMOSU_IMAGE}:$(image_tag)"
}

# ===================================================================
# DOCKER HELPERS
# ===================================================================

# Detect the available compose command: "docker compose" (V2) or "docker-compose" (V1)
COMPOSE_CMD=""
detect_compose_cmd() {
  if [[ -n "$COMPOSE_CMD" ]]; then return; fi
  if docker compose version >/dev/null 2>&1; then
    COMPOSE_CMD="docker compose"
  elif command -v docker-compose >/dev/null 2>&1; then
    COMPOSE_CMD="docker-compose"
  else
    die "Docker Compose is not installed. Install the Docker Compose plugin or standalone docker-compose."
  fi
}

compose_run() {
  detect_compose_cmd
  $COMPOSE_CMD run --rm "$@"
}

# Read a prompt template from the Docker image (no container startup needed for cached images)
read_prompt() {
  local prompt_name="$1"
  docker run --rm --entrypoint cat "$(full_image)" "/opt/kamosu/prompts/${prompt_name}"
}

# Run claude inside Docker with a prompt and allowed tools
docker_claude() {
  local prompt="$1"
  local allowed_tools="$2"
  compose_run kb claude -p "${prompt}" --allowedTools "${allowed_tools}"
}

# ===================================================================
# GIT HELPERS
# ===================================================================

git_pull_if_remote() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi
  if git remote -v 2>/dev/null | grep -q 'origin'; then
    info "Pulling latest changes from remote..."
    git pull --rebase origin "$(git branch --show-current 2>/dev/null || echo main)" 2>/dev/null || warn "Git pull failed. Continuing with local state."
  fi
}

git_push_if_remote() {
  if git remote -v 2>/dev/null | grep -q 'origin'; then
    info "Pushing to remote..."
    git push origin "$(git branch --show-current 2>/dev/null || echo main)" || warn "Git push failed."
  fi
}

# git_commit_and_push MESSAGE PATH [PATH...]
git_commit_and_push() {
  local message="$1"; shift
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    warn "Not a git repository. Skipping commit and push."
    return 0
  fi
  git add "$@"
  git commit -m "$message" || { warn "Nothing to commit."; return 0; }
  git_push_if_remote
}

# ===================================================================
# VERSION HELPERS
# ===================================================================

# Compare two semver strings. Returns: 0 if equal, 1 if $1 > $2, 2 if $1 < $2
version_compare() {
  if [[ "$1" == "$2" ]]; then
    return 0
  fi
  local IFS=.
  local i ver1=($1) ver2=($2)
  for ((i=0; i<3; i++)); do
    local v1="${ver1[i]:-0}"
    local v2="${ver2[i]:-0}"
    if ((v1 > v2)); then
      return 1
    elif ((v1 < v2)); then
      return 2
    fi
  done
  return 0
}

version_gt() {
  version_compare "$1" "$2"
  [[ $? -eq 1 ]]
}

version_le() {
  version_compare "$1" "$2"
  local result=$?
  [[ $result -eq 0 ]] || [[ $result -eq 2 ]]
}

check_version_compat() {
  local image_version
  image_version="$(docker inspect --format '{{index .Config.Labels "kamosu.version"}}' "$(full_image)" 2>/dev/null || true)"
  if [[ -z "$image_version" ]] || [[ "$image_version" == "<no value>" ]]; then
    # Image doesn't have labels (pre-v0.2.0 image or not pulled yet)
    return 0
  fi
  if version_gt "$MIN_IMAGE_VERSION" "$image_version"; then
    warn "Docker image $(full_image) is version ${image_version}, but CLI requires >= ${MIN_IMAGE_VERSION}. Run: kamosu update"
  fi
}

# ===================================================================
# FILE DETECTION (compile)
# ===================================================================

readonly TIMESTAMP_FILE=".last-compile-timestamp"
readonly QUEUE_FILE=".ingest-queue"

detect_changed_files() {
  local opt_force="$1"
  local opt_file="$2"
  local files=()

  if [[ -n "${opt_file}" ]]; then
    if [[ ! -f "${opt_file}" ]]; then
      die "Specified file not found: ${opt_file}"
    fi
    files+=("${opt_file}")
  elif [[ "${opt_force}" == true ]]; then
    while IFS= read -r -d '' file; do
      files+=("${file}")
    done < <(find raw/ -type f -print0 2>/dev/null)
  else
    local find_args=()
    if [[ -f "${TIMESTAMP_FILE}" ]]; then
      find_args=(-newer "${TIMESTAMP_FILE}")
    fi
    while IFS= read -r -d '' file; do
      files+=("${file}")
    done < <(find raw/ -type f "${find_args[@]}" -print0 2>/dev/null)
  fi

  # Also check my-drafts/ for status: to-compile
  if [[ -d "wiki/my-drafts" ]]; then
    local draft_find_args=()
    if [[ "${opt_force}" == false ]] && [[ -f "${TIMESTAMP_FILE}" ]]; then
      draft_find_args=(-newer "${TIMESTAMP_FILE}")
    fi
    while IFS= read -r -d '' file; do
      if grep -q 'status:.*to-compile' "${file}" 2>/dev/null; then
        files+=("${file}")
      fi
    done < <(find wiki/my-drafts/ -type f -name '*.md' "${draft_find_args[@]}" -print0 2>/dev/null)
  fi

  if [[ ${#files[@]} -gt 0 ]]; then
    printf '%s\n' "${files[@]}"
  fi
}

# ===================================================================
# PROMOTE HELPERS
# ===================================================================

readonly HISTORY_FILE=".promote-history"

is_promoted() {
  local file="$1"
  if [[ -f "${HISTORY_FILE}" ]]; then
    grep -qF "	${file}" "${HISTORY_FILE}" 2>/dev/null
  else
    return 1
  fi
}

list_unpromoted() {
  if [[ ! -d "outputs" ]]; then
    info "No outputs/ directory found."
    return 0
  fi

  local found=false
  while IFS= read -r -d '' file; do
    if ! is_promoted "${file}"; then
      echo "  ${file}"
      found=true
    fi
  done < <(find outputs/ -type f -name '*.md' -print0 2>/dev/null | sort -z)

  if [[ "${found}" == false ]]; then
    info "No unpromoted files in outputs/."
  fi
}

record_promoted() {
  local file="$1"
  local timestamp
  timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "${timestamp}	${file}" >> "${HISTORY_FILE}"
}

