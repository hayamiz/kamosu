# === Authentication Mode ===

# Claude OAuth（ホスト認証情報の継承、デフォルト）
# ホストで claude コマンドの OAuth 認証を済ませてから使用してください
COMPOSE_FILE=docker-compose.yml:docker-compose.claude-auth.yml

# AWS Bedrock 認証を使う場合は上の行をコメントアウトし、以下を設定:
# COMPOSE_FILE=docker-compose.yml
# AWS_PROFILE=
# AWS_REGION=

# === Claude Model ===
# e.g., claude-sonnet-4-20250514
ANTHROPIC_MODEL=
