# === kamosu Configuration ===
#
# This file is loaded as env_file by docker-compose.yml.
# To change authentication mode, run: kamosu init --reconfigure

# === Authentication ===
# For Claude OAuth: no variables needed (credentials are mounted automatically)
# For AWS Bedrock: uncomment and set the following:
# AWS_PROFILE=
# AWS_REGION=

# === Claude Model ===
# e.g., claude-sonnet-4-20250514 (OAuth) or us.anthropic.claude-sonnet-4-20250514-v1:0 (Bedrock)
ANTHROPIC_MODEL=
