#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_NAME="kamosu-promote"
readonly HISTORY_FILE=".promote-history"

# Options
OPT_DRY_RUN=false
OPT_LIST=false
OPT_FILES=()

usage() {
    cat <<EOF
Usage: ${SCRIPT_NAME} [OPTIONS] [FILE...]

Promote Q&A outputs into wiki articles.

Takes files from outputs/ (or any specified path) and integrates their
content into the wiki using Claude Code. The LLM decides whether to
create new articles or merge into existing ones, following the same
protocol as compilation.

Options:
  --dry-run       Show the integration plan without making changes
  --list          Show unpromoted files in outputs/
  --file PATH     Promote a file outside outputs/ (repeatable)
  -h, --help      Show this help message

Examples:
  ${SCRIPT_NAME} outputs/analysis-2026-04-06.md
  ${SCRIPT_NAME} outputs/comparison-*.md
  ${SCRIPT_NAME} --dry-run outputs/analysis.md
  ${SCRIPT_NAME} --list
  ${SCRIPT_NAME} --file /tmp/external-notes.md
EOF
}

error() {
    echo "ERROR: $1" >&2
    echo "Run '${SCRIPT_NAME} --help' for usage information." >&2
    exit 1
}

info() {
    echo "[${SCRIPT_NAME}] $1"
}

warn() {
    echo "[${SCRIPT_NAME}] WARNING: $1" >&2
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                OPT_DRY_RUN=true; shift ;;
            --list)
                OPT_LIST=true; shift ;;
            --file)
                [[ $# -lt 2 ]] && error "--file requires a path argument."
                OPT_FILES+=("$2"); shift 2 ;;
            -h|--help)
                usage; exit 0 ;;
            -*)
                error "Unknown option: $1" ;;
            *)
                OPT_FILES+=("$1"); shift ;;
        esac
    done
}

check_prerequisites() {
    if [[ ! -f "CLAUDE.md" ]]; then
        error "CLAUDE.md not found. Are you in a kamosu data repository?"
    fi

    if [[ ! -d "wiki" ]]; then
        error "wiki/ directory not found. Are you in a kamosu data repository?"
    fi
}

is_promoted() {
    local file="$1"
    if [[ -f "${HISTORY_FILE}" ]]; then
        # Match the file path (second field, tab-separated)
        grep -qF "	${file}" "${HISTORY_FILE}" 2>/dev/null
    else
        return 1
    fi
}

list_unpromoted() {
    if [[ ! -d "outputs" ]]; then
        info "No outputs/ directory found."
        exit 0
    fi

    local found=false
    while IFS= read -r -d '' file; do
        if ! is_promoted "${file}"; then
            echo "  ${file}"
            found=true
        fi
    done < <(find outputs/ -type f -name '*.md' -print0 2>/dev/null | sort -z)

    if [[ "${found}" == false ]]; then
        info "No unpromoted files in outputs/."
    fi
}

record_promoted() {
    local file="$1"
    local timestamp
    timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "${timestamp}	${file}" >> "${HISTORY_FILE}"
}

main() {
    parse_args "$@"
    check_prerequisites

    # --list mode
    if [[ "${OPT_LIST}" == true ]]; then
        info "Unpromoted files in outputs/:"
        list_unpromoted
        exit 0
    fi

    # Validate files
    if [[ ${#OPT_FILES[@]} -eq 0 ]]; then
        error "No files specified. Provide file paths or use --list to see candidates."
    fi

    for file in "${OPT_FILES[@]}"; do
        if [[ ! -f "${file}" ]]; then
            error "File not found: ${file}"
        fi
    done

    # Show files to promote
    local file_count=${#OPT_FILES[@]}
    info "Promoting ${file_count} file(s):"
    for file in "${OPT_FILES[@]}"; do
        echo "  - ${file}"
    done

    # Dry run — build prompt but only show plan
    if [[ "${OPT_DRY_RUN}" == true ]]; then
        info "Dry run: showing integration plan..."

        local file_list
        file_list=$(printf '%s\n' "${OPT_FILES[@]}")

        local prompt="Read /opt/kamosu/claude-base.md for the base protocol.

I want to promote the following Q&A output(s) into wiki articles:
${file_list}

Read each file, then read _master_index.md and relevant category indexes.
Analyze the content and produce an integration plan:
- For each file, state whether it should become a new article or be merged into an existing one
- If merging, name the target article(s)
- List which indexes would be updated

DO NOT make any changes. Only output the plan."

        claude -p "${prompt}" --allowedTools "Read,Glob,Grep"
        info "Dry run complete. No changes were made."
        exit 0
    fi

    # Full promote
    info "Invoking Claude Code for promotion..."

    local file_list
    file_list=$(printf '%s\n' "${OPT_FILES[@]}")

    local prompt="Read /opt/kamosu/claude-base.md for the base protocol.

Promote the following Q&A output(s) into wiki articles:
${file_list}

Follow the Promote Protocol (Section 7 of claude-base.md):
1. Read each source file and understand the content.
2. Read _master_index.md and relevant category indexes to find integration targets.
3. Either create new articles in wiki/concepts/ or merge into existing articles.
   - Follow Article Format (Section 2) for new articles.
   - Add the output file path to the sources: frontmatter field.
4. Add backlinks from related articles.
5. Update all indexes: _master_index.md, affected _category/*.md, _cross_references.md.
6. Append a promote entry to wiki/_log.md:
   ## [$(date +%Y-%m-%d)] promote | <summary>
   - Promoted: <file list>
   - Created/updated articles: [[article-a]], [[article-b]]"

    claude -p "${prompt}" --allowedTools "Edit,Write,Read,Glob,Grep"

    # Record promoted files
    for file in "${OPT_FILES[@]}"; do
        record_promoted "${file}"
    done
    info "Recorded ${file_count} file(s) in ${HISTORY_FILE}."

    # Git commit
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        info "Committing changes..."
        git add wiki/ "${HISTORY_FILE}"
        git commit -m "promote: integrated ${file_count} file(s) into wiki

Files promoted:
${file_list}" || warn "Nothing to commit."

        # Push if remote exists
        if git remote -v 2>/dev/null | grep -q 'origin'; then
            info "Pushing to remote..."
            git push origin "$(git branch --show-current 2>/dev/null || echo main)" || warn "Git push failed."
        fi
    else
        warn "Not a git repository. Skipping commit and push."
    fi

    info "Promotion complete!"
}

main "$@"
