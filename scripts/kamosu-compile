#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_NAME="kamosu-compile"
readonly CLAUDE_BASE="/opt/kamosu/claude-base.md"
readonly TIMESTAMP_FILE=".last-compile-timestamp"
readonly QUEUE_FILE=".ingest-queue"

# Options
OPT_FORCE=false
OPT_DRY_RUN=false
OPT_FILE=""

usage() {
    cat <<EOF
Usage: ${SCRIPT_NAME} [OPTIONS]

Compile raw data into wiki articles using Claude Code.

Detects new or updated files in raw/ since the last compilation,
then invokes Claude Code to process them according to the wiki protocol.

Options:
  --force       Recompile all raw files regardless of timestamp
  --dry-run     Show files that would be compiled without running compilation
  --file PATH   Compile a specific file only
  -h, --help    Show this help message

Examples:
  ${SCRIPT_NAME}                    # Compile new/updated files
  ${SCRIPT_NAME} --force            # Recompile everything
  ${SCRIPT_NAME} --dry-run          # Preview what would be compiled
  ${SCRIPT_NAME} --file raw/papers/new-paper.pdf
EOF
}

error() {
    echo "ERROR: $1" >&2
    echo "Run '${SCRIPT_NAME} --help' for usage information." >&2
    exit 1
}

info() {
    echo "[${SCRIPT_NAME}] $1"
}

warn() {
    echo "[${SCRIPT_NAME}] WARNING: $1" >&2
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)
                OPT_FORCE=true
                shift
                ;;
            --dry-run)
                OPT_DRY_RUN=true
                shift
                ;;
            --file)
                if [[ $# -lt 2 ]]; then
                    error "--file requires a path argument."
                fi
                OPT_FILE="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                error "Unknown option: $1"
                ;;
        esac
    done
}

check_prerequisites() {
    if [[ ! -f "CLAUDE.md" ]]; then
        error "CLAUDE.md not found. Are you in a kamosu data repository?"
    fi

    if [[ ! -d "raw" ]]; then
        error "raw/ directory not found. Are you in a kamosu data repository?"
    fi

    if [[ ! -d "wiki" ]]; then
        error "wiki/ directory not found. Are you in a kamosu data repository?"
    fi
}

git_pull_if_remote() {
    if git remote -v 2>/dev/null | grep -q 'origin'; then
        info "Pulling latest changes from remote..."
        git pull --rebase origin "$(git branch --show-current 2>/dev/null || echo main)" 2>/dev/null || warn "Git pull failed. Continuing with local state."
    fi
}

detect_changed_files() {
    local files=()

    if [[ -n "${OPT_FILE}" ]]; then
        # Specific file mode
        if [[ ! -f "${OPT_FILE}" ]]; then
            error "Specified file not found: ${OPT_FILE}"
        fi
        files+=("${OPT_FILE}")
    elif [[ "${OPT_FORCE}" == true ]]; then
        # Force mode — all raw files
        while IFS= read -r -d '' file; do
            files+=("${file}")
        done < <(find raw/ -type f -print0 2>/dev/null)
    else
        # Normal mode — files newer than timestamp
        if [[ -f "${TIMESTAMP_FILE}" ]]; then
            while IFS= read -r -d '' file; do
                files+=("${file}")
            done < <(find raw/ -type f -newer "${TIMESTAMP_FILE}" -print0 2>/dev/null)
        else
            # No timestamp file — treat all files as new
            while IFS= read -r -d '' file; do
                files+=("${file}")
            done < <(find raw/ -type f -print0 2>/dev/null)
        fi
    fi

    printf '%s\n' "${files[@]}"
}

write_queue() {
    local files=("$@")
    printf '%s\n' "${files[@]}" > "${QUEUE_FILE}"
}

build_compile_prompt() {
    local queue_file="$1"
    cat <<EOF
以下の指示に従って、raw データを wiki にコンパイルしてください。

## 基本プロトコル
$(cat "${CLAUDE_BASE}")

## この知識ベースの設定
$(cat CLAUDE.md)

## コンパイル対象ファイル
$(cat "${queue_file}")

## 指示
1. 上記のコンパイル対象ファイルを読み込んでください。
2. Compilation Protocol（基本プロトコルのセクション3）の6ステップに従って処理してください。
3. 新規記事の作成、または既存記事の更新を行ってください。
4. 必ずインデックス（_master_index.md, _category/*.md, _cross_references.md）を更新してください。
EOF
}

main() {
    parse_args "$@"
    check_prerequisites

    # Step 1: Git pull
    git_pull_if_remote

    # Step 2: Detect changed files
    info "Scanning for new/updated files in raw/..."
    local changed_files
    changed_files=$(detect_changed_files)

    if [[ -z "${changed_files}" ]]; then
        info "No new or updated files found. Nothing to compile."
        exit 0
    fi

    # Count files
    local file_count
    file_count=$(echo "${changed_files}" | wc -l)
    info "Found ${file_count} file(s) to compile:"
    echo "${changed_files}" | while IFS= read -r f; do
        echo "  - ${f}"
    done

    # Step 3: Write ingest queue
    echo "${changed_files}" > "${QUEUE_FILE}"

    # Dry run — stop here
    if [[ "${OPT_DRY_RUN}" == true ]]; then
        info "Dry run complete. Files listed above would be compiled."
        rm -f "${QUEUE_FILE}"
        exit 0
    fi

    # Step 4: Invoke Claude Code
    info "Invoking Claude Code for compilation..."
    local prompt
    prompt=$(build_compile_prompt "${QUEUE_FILE}")

    claude -p "${prompt}"

    # Step 5: Update timestamp
    touch "${TIMESTAMP_FILE}"
    info "Updated ${TIMESTAMP_FILE}."

    # Step 6: Clean up queue
    rm -f "${QUEUE_FILE}"

    # Step 7: Git commit
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        info "Committing changes..."
        git add wiki/ "${TIMESTAMP_FILE}"
        git commit -m "compile: processed ${file_count} file(s)

Files compiled:
${changed_files}" || warn "Nothing to commit."

        # Step 8: Push if remote exists
        if git remote -v 2>/dev/null | grep -q 'origin'; then
            info "Pushing to remote..."
            git push origin "$(git branch --show-current 2>/dev/null || echo main)" || warn "Git push failed."
        fi
    else
        warn "Not a git repository. Skipping commit and push."
    fi

    info "Compilation complete!"
}

main "$@"
